---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../data/site";

const groups = [
  {
    title: "李沐 | 动手学深度学习",
    description: "围绕深度学习基础、PyTorch 实践和课程视频整理的学习入口。",
    links: [
      {
        name: "网站",
        description: "《动手学深度学习》在线教材。",
        href: "https://zh.d2l.ai/",
      },
      {
        name: "bilibili 主页",
        description: "李沐《动手学深度学习》系列视频列表。",
        href: "https://space.bilibili.com/1567748478/lists/358497?type=series",
      },
    ],
  },
];
---

<BaseLayout title={`Deep Learning | ${site.owner}`} description="Deep Learning 学习资料推荐。">
  <div class="page-shell" id="top">
    <Header />

    <main class="resource-shell">
      <section class="container">
        <a class="back-link" href="/#resources">返回资料推荐</a>
        <SectionHeading
          eyebrow="Resources"
          title="Deep Learning"
          lede="深度学习相关教材、课程和长期参考资料。"
        />

        <div class="resource-stack">
          {
            groups.map((group) => (
              <article class="resource-group-panel">
                <div class="group-heading">
                  <h3>{group.title}</h3>
                  <p>{group.description}</p>
                </div>
                <div class="resource-links">
                  {
                    group.links.map((link) => (
                      <a
                        class="card resource-link-card"
                        href={link.href}
                        target="_blank"
                        rel="noreferrer"
                      >
                        <strong>{link.name}</strong>
                        <span>{link.description}</span>
                      </a>
                    ))
                  }
                </div>
              </article>
            ))
          }
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
  .resource-shell {
    padding: calc(var(--header-height) + 72px) 0 96px;
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 28px;
    color: var(--text-muted);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .back-link:hover {
    color: var(--text);
  }

  .resource-stack {
    display: grid;
    gap: 16px;
  }

  .resource-group-panel {
    display: grid;
    grid-template-columns: minmax(0, 0.45fr) minmax(0, 0.55fr);
    gap: 24px;
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.72);
  }

  .group-heading {
    display: grid;
    align-content: start;
    gap: 8px;
  }

  h3 {
    margin: 0;
    color: #2a2a2a;
  }

  p {
    margin: 0;
    color: var(--text-muted);
  }

  .resource-links {
    display: grid;
    gap: 12px;
  }

  .resource-link-card {
    display: grid;
    gap: 8px;
    padding: 18px;
  }

  strong {
    line-height: 1.3;
  }

  span {
    color: var(--text-muted);
    font-size: 0.92rem;
  }

  @media (max-width: 820px) {
    .resource-shell {
      padding: calc(var(--header-height) + 52px) 0 72px;
    }

    .resource-group-panel {
      grid-template-columns: 1fr;
      gap: 18px;
      padding: 20px;
    }
  }
</style>
