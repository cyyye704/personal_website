---
import { getCollection, render } from "astro:content";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../data/site";

export async function getStaticPaths() {
  const entries = await getCollection("methodology");

  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout
  title={`${entry.data.title} | ${site.owner}`}
  description={entry.data.description ?? site.description}
>
  <div class="page-shell" id="top">
    <Header />

    <main class="article-shell">
      <article class="container article">
        <a class="back-link" href="/#methodology">返回方法论</a>
        <p class="eyebrow">Methodology</p>
        <h1>{entry.data.title}</h1>
        {
          entry.data.description && (
            <p class="article-description">{entry.data.description}</p>
          )
        }
        <div class="article-content">
          <Content />
        </div>
      </article>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
  .article-shell {
    padding: calc(var(--header-height) + 72px) 0 96px;
  }

  .article {
    max-width: 820px;
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 28px;
    color: var(--text-muted);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .back-link:hover {
    color: var(--text);
  }

  h1 {
    max-width: 760px;
    font-size: clamp(2.2rem, 6vw, 4.2rem);
    line-height: 1.05;
  }

  .article-description {
    max-width: 680px;
    margin-bottom: 42px;
    color: var(--text-muted);
    font-size: 1.08rem;
  }

  .article-content {
    display: grid;
    gap: 18px;
    color: #242424;
    font-size: 1.02rem;
  }

  .article-content :global(h2) {
    margin: 32px 0 0;
    font-size: clamp(1.45rem, 3vw, 2rem);
  }

  .article-content :global(h3) {
    margin: 20px 0 0;
  }

  .article-content :global(p),
  .article-content :global(ul),
  .article-content :global(ol),
  .article-content :global(blockquote) {
    margin: 0;
  }

  .article-content :global(a) {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .article-content :global(blockquote) {
    padding-left: 18px;
    border-left: 3px solid var(--line-strong);
    color: var(--text-muted);
  }

  .article-content :global(code) {
    padding: 2px 5px;
    border-radius: 4px;
    background: var(--surface-muted);
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    font-size: 0.92em;
  }

  .article-content :global(pre) {
    overflow-x: auto;
    padding: 16px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
  }

  .article-content :global(pre code) {
    padding: 0;
    background: transparent;
  }
</style>
