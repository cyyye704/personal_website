---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MethodCard from "../components/MethodCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ResourceGroup from "../components/ResourceGroup.astro";
import SectionHeading from "../components/SectionHeading.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import {
  navItems,
  news,
  platforms,
  projects,
  resources,
  site,
} from "../data/site";

const methodologyEntries = (await getCollection("methodology")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout>
  <div class="page-shell" id="top">
    <Header />

    <main>
      <section class="hero">
        <div class="container hero-inner">
          <div class="hero-copy">
            <h1 class="hero-title">{site.title}</h1>
            <div class="platform-links" aria-label="媒体平台链接">
              {
                platforms.map((platform) =>
                  platform.action === "wechat" ? (
                    <button
                      class="platform-link"
                      type="button"
                      data-wechat-trigger
                      aria-controls="wechat-panel"
                      aria-expanded="false"
                    >
                      <span class="platform-icon" aria-hidden="true">
                        {platform.icon}
                      </span>
                      <span>{platform.name}</span>
                    </button>
                  ) : (
                    <a class="platform-link" href={platform.href}>
                      <span class="platform-icon" aria-hidden="true">
                        {platform.icon}
                      </span>
                      <span>{platform.name}</span>
                    </a>
                  )
                )
              }
            </div>
            <p class="hero-description">{site.description}</p>
            <div class="hero-actions" aria-label="页面栏目导航">
              {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
            </div>
          </div>

          <div class="signal-panel" aria-label="个人方向概览">
            <div>
              <span>Focus</span>
              <strong>AI × Engineering</strong>
            </div>
            <div>
              <span>Mode</span>
              <strong>Engineering Practice</strong>
            </div>
            <div>
              <span>Horizon</span>
              <strong>Long-term Systems</strong>
            </div>
          </div>
        </div>
      </section>

      <section class="section" id="projects">
        <div class="container">
          <SectionHeading
            eyebrow="Projects"
            title="项目"
          />
          <div class="grid two">
            {projects.map((project) => <ProjectCard {...project} />)}
          </div>
        </div>
      </section>

      <section class="section" id="methodology">
        <div class="container">
          <SectionHeading
            eyebrow="Methodology"
            title="方法论"
          />
          <div
            class="methodology-strip"
            data-drag-strip
            aria-label="方法论条目"
          >
            {
              methodologyEntries.map((entry, index) => (
                <div class="methodology-item">
                  <MethodCard
                    title={entry.data.title}
                    href={`/methodology/${entry.slug}/`}
                    index={index}
                  />
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <section class="section" id="resources">
        <div class="container">
          <SectionHeading
            eyebrow="Resources"
            title="资料推荐"
          />
          <div class="grid two">
            {
              resources.map((group) => (
                <ResourceGroup category={group.category} items={group.items} />
              ))
            }
          </div>
        </div>
      </section>

      <section class="section news-section" id="news">
        <div class="container">
          <SectionHeading
            eyebrow="News"
            title="新闻"
          />
          <ol class="timeline" aria-label="个人动态">
            {
              news.map((item) => (
                <li>
                  <time>{item.date}</time>
                  <span>{item.text}</span>
                </li>
              ))
            }
          </ol>
        </div>
      </section>
    </main>

    <div class="wechat-overlay" data-wechat-overlay hidden></div>
    <aside
      class="wechat-panel"
      id="wechat-panel"
      data-wechat-panel
      aria-hidden="true"
    >
      <button
        class="wechat-close"
        type="button"
        data-wechat-close
        aria-label="关闭微信二维码"
      >
        ×
      </button>
      <div class="wechat-card">
        <img src="/wechat-qr.png" alt="微信二维码" loading="lazy" />
      </div>
    </aside>

    <Footer />
  </div>
</BaseLayout>

<script>
  const wechatTrigger = document.querySelector("[data-wechat-trigger]");
  const wechatOverlay = document.querySelector("[data-wechat-overlay]");
  const wechatPanel = document.querySelector("[data-wechat-panel]");
  const wechatClose = document.querySelector("[data-wechat-close]");

  const setWechatOpen = (isOpen) => {
    if (!wechatTrigger || !wechatOverlay || !wechatPanel) {
      return;
    }

    wechatOverlay.hidden = !isOpen;
    wechatOverlay.classList.toggle("is-open", isOpen);
    wechatPanel.classList.toggle("is-open", isOpen);
    wechatPanel.setAttribute("aria-hidden", String(!isOpen));
    wechatTrigger.setAttribute("aria-expanded", String(isOpen));
    document.documentElement.classList.toggle("wechat-open", isOpen);
  };

  wechatTrigger?.addEventListener("click", () => {
    const isOpen = wechatPanel?.classList.contains("is-open") ?? false;
    setWechatOpen(!isOpen);
  });

  wechatOverlay?.addEventListener("click", () => setWechatOpen(false));
  wechatClose?.addEventListener("click", () => setWechatOpen(false));

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      setWechatOpen(false);
    }
  });

  const dragStrip = document.querySelector<HTMLElement>("[data-drag-strip]");
  let dragStartX = 0;
  let dragStartScrollLeft = 0;
  let isPendingStripDrag = false;
  let shouldSuppressStripClick = false;

  dragStrip?.addEventListener("pointerdown", (event) => {
    if (event.button !== 0 || event.pointerType !== "mouse") {
      return;
    }

    isPendingStripDrag = true;
    shouldSuppressStripClick = false;
    dragStartX = event.clientX;
    dragStartScrollLeft = dragStrip.scrollLeft;
  });

  dragStrip?.addEventListener("pointermove", (event) => {
    if (!isPendingStripDrag || !dragStrip) {
      return;
    }

    const distance = event.clientX - dragStartX;
    if (Math.abs(distance) <= 6) {
      return;
    }

    event.preventDefault();
    shouldSuppressStripClick = true;
    dragStrip.classList.add("is-dragging");
    dragStrip.scrollLeft = dragStartScrollLeft - distance;
  });

  const stopDraggingStrip = () => {
    if (!isPendingStripDrag || !dragStrip) {
      return;
    }

    isPendingStripDrag = false;
    dragStrip.classList.remove("is-dragging");
    window.setTimeout(() => {
      shouldSuppressStripClick = false;
    }, 0);
  };

  window.addEventListener("pointerup", stopDraggingStrip);
  window.addEventListener("pointercancel", stopDraggingStrip);
  dragStrip?.addEventListener(
    "click",
    (event) => {
      if (!shouldSuppressStripClick) {
        return;
      }

      event.preventDefault();
      event.stopPropagation();
    },
    true,
  );
</script>

<style>
  .hero {
    min-height: 100vh;
    padding: calc(var(--header-height) + 84px) 0 92px;
  }

  .hero-inner {
    display: grid;
    min-height: calc(100vh - var(--header-height) - 176px);
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 48px;
    align-items: center;
  }

  .hero-copy {
    min-width: 0;
  }

  .hero-title {
    max-width: 760px;
    font-size: clamp(2rem, 4.4vw, 3.8rem);
    line-height: 1.04;
  }

  .platform-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 0 0 24px;
  }

  .platform-link {
    appearance: none;
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    gap: 8px;
    padding: 7px 12px 7px 8px;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.72);
    color: var(--text);
    cursor: pointer;
    font-family: inherit;
    font-size: 0.92rem;
    font-weight: 700;
    line-height: 1;
    transition:
      background-color 140ms ease,
      border-color 140ms ease,
      transform 140ms ease;
  }

  .platform-link:hover {
    transform: translateY(-2px);
    border-color: var(--line-strong);
    background: var(--surface);
  }

  .platform-link:focus-visible,
  .wechat-close:focus-visible {
    outline: 2px solid var(--text);
    outline-offset: 3px;
  }

  .platform-icon {
    display: grid;
    width: 22px;
    height: 22px;
    flex: 0 0 auto;
    place-items: center;
    border-radius: 5px;
    color: var(--surface);
    background: var(--text);
    font-size: 0.74rem;
    line-height: 1;
  }

  .hero-description {
    max-width: 680px;
    margin-bottom: 34px;
    color: var(--text-muted);
    font-size: clamp(1rem, 2vw, 1.2rem);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .hero-actions a {
    display: inline-flex;
    align-items: center;
    min-height: 42px;
    padding: 9px 14px;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.72);
    color: var(--text);
    font-weight: 700;
    transition:
      background-color 140ms ease,
      border-color 140ms ease,
      transform 140ms ease;
  }

  .hero-actions a:hover {
    transform: translateY(-2px);
    border-color: var(--line-strong);
    background: var(--surface);
  }

  .signal-panel {
    position: relative;
    display: grid;
    gap: 0;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background:
      linear-gradient(135deg, rgba(17, 17, 17, 0.05), transparent 45%),
      rgba(255, 255, 255, 0.78);
    box-shadow: 0 20px 60px rgba(17, 17, 17, 0.06);
  }

  .signal-panel::before {
    position: absolute;
    inset: 16px;
    border: 1px solid rgba(17, 17, 17, 0.08);
    border-radius: 5px;
    content: "";
    pointer-events: none;
  }

  .signal-panel div {
    display: grid;
    gap: 6px;
    padding: 28px;
    border-bottom: 1px solid var(--line);
  }

  .signal-panel div:last-child {
    border-bottom: 0;
  }

  .signal-panel span {
    color: var(--text-muted);
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    font-size: 0.78rem;
    text-transform: uppercase;
  }

  .signal-panel strong {
    font-size: 1.05rem;
  }

  .methodology-strip {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    overscroll-behavior-x: contain;
    padding: 2px 0 14px;
    cursor: grab;
    scroll-snap-type: x proximity;
    scrollbar-color: var(--line-strong) transparent;
    scrollbar-width: thin;
    user-select: none;
  }

  .methodology-strip.is-dragging {
    cursor: grabbing;
    scroll-snap-type: none;
  }

  .methodology-item {
    flex: 0 0 clamp(236px, 28vw, 292px);
    scroll-snap-align: start;
  }

  .news-section {
    padding-bottom: 88px;
  }

  .timeline {
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--line);
  }

  .timeline li {
    display: grid;
    grid-template-columns: 148px minmax(0, 1fr);
    gap: 24px;
    padding: 22px 0;
    border-bottom: 1px solid var(--line);
  }

  time {
    color: var(--text-muted);
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  }

  :global(html.wechat-open) {
    overflow: hidden;
  }

  .wechat-overlay {
    position: fixed;
    z-index: 40;
    inset: 0;
    background: rgba(17, 17, 17, 0.32);
    opacity: 0;
    transition: opacity 180ms ease;
  }

  .wechat-overlay.is-open {
    opacity: 1;
  }

  .wechat-panel {
    position: fixed;
    z-index: 45;
    top: 0;
    right: 0;
    display: flex;
    width: min(420px, 42vw);
    height: 100dvh;
    align-items: center;
    justify-content: center;
    padding: calc(var(--header-height) + 28px) 28px 28px;
    border-left: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.96);
    box-shadow: -24px 0 60px rgba(17, 17, 17, 0.14);
    transform: translateX(100%);
    transition: transform 220ms ease;
  }

  .wechat-panel.is-open {
    transform: translateX(0);
  }

  .wechat-close {
    appearance: none;
    position: absolute;
    top: 20px;
    right: 20px;
    display: grid;
    width: 36px;
    height: 36px;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    font: inherit;
    font-size: 1.2rem;
    line-height: 1;
  }

  .wechat-card {
    display: grid;
    width: min(100%, 360px);
    aspect-ratio: 827 / 1103;
    place-items: center;
  }

  .wechat-card img {
    width: 100%;
    height: 100%;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    object-fit: contain;
  }

  @media (max-width: 960px) {
    .hero-inner {
      grid-template-columns: 1fr;
      align-items: end;
    }

    .signal-panel {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .signal-panel div {
      border-right: 1px solid var(--line);
      border-bottom: 0;
    }

    .signal-panel div:last-child {
      border-right: 0;
    }

    .methodology-item {
      flex-basis: clamp(220px, 40vw, 280px);
    }
  }

  @media (max-width: 640px) {
    .hero {
      min-height: auto;
      padding: calc(var(--header-height) + 56px) 0 64px;
    }

    .hero-inner {
      min-height: auto;
      gap: 36px;
    }

    .hero-title {
      font-size: clamp(1.85rem, 10vw, 2.6rem);
    }

    .hero-actions a {
      flex: 1 1 calc(50% - 10px);
      justify-content: center;
    }

    .wechat-panel {
      top: auto;
      right: 0;
      bottom: 0;
      left: 0;
      width: 100%;
      height: min(82dvh, 680px);
      padding: 52px 20px 24px;
      border-top: 1px solid var(--line);
      border-left: 0;
      border-radius: 8px 8px 0 0;
      box-shadow: 0 -24px 60px rgba(17, 17, 17, 0.16);
      transform: translateY(100%);
    }

    .wechat-panel.is-open {
      transform: translateY(0);
    }

    .wechat-card {
      width: min(78vw, 320px);
      max-height: calc(82dvh - 96px);
    }

    .methodology-item {
      flex-basis: min(82vw, 280px);
    }

    .signal-panel {
      grid-template-columns: 1fr;
    }

    .signal-panel div {
      padding: 22px;
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }

    .signal-panel div:last-child {
      border-bottom: 0;
    }

    .timeline li {
      grid-template-columns: 1fr;
      gap: 6px;
    }
  }
</style>
