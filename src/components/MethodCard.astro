---
interface Props {
  title: string;
  index: number;
  href: string;
}

const { title, index, href } = Astro.props;
const paddedIndex = String(index + 1).padStart(2, "0");
---

<a class="card method-card" href={href}>
  <span>{paddedIndex}</span>
  <h3>{title}</h3>
</a>

<style>
  .method-card {
    display: grid;
    height: 100%;
    min-height: 168px;
    align-content: space-between;
    gap: 18px;
    padding: 22px;
  }

  .method-card:hover {
    color: inherit;
  }

  span {
    color: var(--text-muted);
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    font-size: 0.84rem;
  }

  h3 {
    margin: 0;
  }
</style>
