---
interface Resource {
  name: string;
  description: string;
  href: string;
}

interface Props {
  category: string;
  items: Resource[];
}

const { category, items } = Astro.props;
---

<article class="resource-group">
  <h3>{category}</h3>
  <div class="resource-list">
    {
      items.map((item) => (
        <a class="card resource-card" href={item.href}>
          <strong>{item.name}</strong>
          <span>{item.description}</span>
        </a>
      ))
    }
  </div>
</article>

<style>
  .resource-group {
    display: grid;
    gap: 14px;
  }

  h3 {
    margin: 0;
    color: #2a2a2a;
  }

  .resource-list {
    display: grid;
    gap: 12px;
  }

  .resource-card {
    display: grid;
    gap: 8px;
    padding: 18px;
  }

  strong {
    line-height: 1.3;
  }

  span {
    color: var(--text-muted);
    font-size: 0.92rem;
  }
</style>
