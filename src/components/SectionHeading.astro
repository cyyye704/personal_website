---
interface Props {
  eyebrow: string;
  title: string;
  lede?: string;
}

const { eyebrow, title, lede } = Astro.props;
---

<div class:list={["section-header", { "has-lede": lede }]}>
  <div>
    <p class="eyebrow">{eyebrow}</p>
    <h2>{title}</h2>
  </div>
  {lede && <p class="section-lede">{lede}</p>}
</div>
