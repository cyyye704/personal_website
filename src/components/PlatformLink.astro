---
interface Props {
  name: string;
  href: string;
  handle: string;
}

const { name, href, handle } = Astro.props;
---

<a class="card platform-link" href={href} aria-label={`${name}: ${handle}`}>
  <span class="platform-name">{name}</span>
  <span class="platform-handle">{handle}</span>
</a>

<style>
  .platform-link {
    display: grid;
    min-height: 112px;
    align-content: space-between;
    gap: 16px;
    padding: 20px;
  }

  .platform-name {
    color: var(--text);
    font-weight: 800;
  }

  .platform-handle {
    color: var(--text-muted);
    font-size: 0.9rem;
  }
</style>
